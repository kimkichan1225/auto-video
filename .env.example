# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI (Whisper STT + 대본 생성)
OPENAI_API_KEY=sk-...

# Gemini (참고 영상 분석 및 매칭)
# 발급: https://aistudio.google.com/apikey  ← "Create in new project" 권장
GEMINI_API_KEY=AIza...
# 사용할 Gemini 모델 (기본: gemini-2.0-flash, 무료 할당량 문제 시 gemini-1.5-flash로 교체)
GEMINI_MODEL=gemini-2.0-flash

# Typecast Developer API (X-API-KEY 인증)
# 키 발급: https://typecast.ai/developers
TYPECAST_API_KEY=
TYPECAST_API_BASE=https://api.typecast.ai/v1
# 사용할 Voice ID (필수) — tc_로 시작하는 ID
# 복사: https://typecast.ai/developers/api/voices
TYPECAST_ACTOR_ID=tc_xxxxxxxxxxxxxxxxxxxxxxxx
